{
  "compilerOptions": {
    "strict": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    // Deferred — pure notation churn, no robustness gain:
    // noPropertyAccessFromIndexSignature (169 errors).

    "target": "ES2022",
    "lib": ["ESNext"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@maxjustus/chwire/native": ["./native/index.ts"],
      "@maxjustus/chwire/tcp": ["./tcp_client/index.ts"]
    }
  },
  "include": ["*.ts", "native/**/*.ts", "test/**/*.ts", "tcp_client/**/*.ts", "types.d.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
