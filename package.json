{
  "name": "@maxjustus/chwire",
  "version": "1.0.0",
  "description": "ClickHouse HTTP/TCP client and Native wire format toolkit for TypeScript",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/chwire.js",
  "bin": {
    "chwire": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chwire.js",
      "require": "./dist/chwire.cjs"
    },
    "./lz4": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chwire-lz4.js",
      "require": "./dist/chwire-lz4.cjs"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "import": "./dist/native.js",
      "require": "./dist/native.cjs"
    },
    "./source": "./index.ts",
    "./tcp": {
      "types": "./dist/tcp_client/index.d.ts",
      "import": "./dist/tcp.js",
      "require": "./dist/tcp.cjs"
    }
  },
  "files": [
    "dist",
    "vendor",
    "CHANGELOG.md",
    "index.ts",
    "client.ts",
    "compression.ts",
    "errors.ts",
    "params.ts",
    "settings.ts",
    "settings.generated.ts",
    "types.ts",
    "types.d.ts",
    "util.ts",
    "native/**/*.ts",
    "tcp_client/*.ts"
  ],
  "scripts": {
    "prepare": "cp .hooks/* .git/hooks/ 2>/dev/null || true",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "build": "npm run clean && node scripts/build.mjs && npm run build:copy-wasm && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "build:copy-wasm": "cp node_modules/@bokuweb/zstd-wasm/dist/common/zstd.wasm dist/",
    "test": "tsc --noEmit && tsx --test test/native/*.test.ts test/*.test.ts tcp_client/test/*.test.ts",
    "test:matrix": "node scripts/test-matrix.mjs",
    "test:compression": "tsx --test test/compression.test.ts",
    "test:integration": "tsx --test test/http-integration.test.ts test/native/integration.test.ts test/native/integration_matrix.test.ts",
    "test:native": "tsx --test test/native/*.test.ts",
    "test:dist": "npm run build && node test/test-dist.mjs",
    "test:fuzz": "tsx fuzz/parallel.ts --all",
    "test:fuzz:verbose": "tsx fuzz/parallel.ts --all --verbose",
    "test:tcp": "tsx --test tcp_client/test/*.test.ts",
    "bench": "tsx bench/formats.ts",
    "bench:check": "tsc -p tsconfig.bench.json",
    "bench:compression": "tsx bench/compression.ts",
    "bench:tcp": "tsx bench/tcp-read-profile.ts --cli",
    "vendor:lz4": "npx jsr add @nick/lz4 && cp node_modules/@nick/lz4/lib/lz4.js node_modules/@nick/lz4/lib/lz4.internal.js vendor/lz4/ && rm -rf node_modules/@nick",
    "format": "biome format --write .",
    "format:check": "biome check ."
  },
  "author": "maxjustus",
  "license": "MIT",
  "dependencies": {
    "@bokuweb/zstd-wasm": "^0.0.27",
    "ch-city-wasm": "^0.1.1"
  },
  "optionalDependencies": {
    "lz4-napi": "^2.9.0",
    "zstd-napi": "^0.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@testcontainers/clickhouse": "^11.5.1",
    "esbuild": "^0.27.0",
    "playwright": "^1.61.0",
    "testcontainers": "^11.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
