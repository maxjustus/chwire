{
  "name": "@maxjustus/chwire",
  "version": "1.0.0",
  "description": "ClickHouse HTTP/TCP client and Native/RowBinary wire format toolkit for TypeScript",
  "type": "module",
  "main": "./dist/chwire.js",
  "bin": {
    "chwire": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chwire.js",
      "require": "./dist/chwire.cjs"
    },
    "./lz4": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chwire-lz4.js",
      "require": "./dist/chwire-lz4.cjs"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "development": "./native/index.ts",
      "import": "./dist/native.js",
      "require": "./dist/native.cjs"
    },
    "./source": "./index.ts",
    "./tcp": {
      "types": "./dist/tcp_client/index.d.ts",
      "development": "./tcp_client/index.ts",
      "import": "./dist/tcp.js",
      "require": "./dist/tcp.cjs"
    }
  },
  "files": [
    "dist",
    "vendor",
    "CHANGELOG.md",
    "index.ts",
    "client.ts",
    "compression.ts",
    "errors.ts",
    "params.ts",
    "settings.ts",
    "settings.generated.ts",
    "types.ts",
    "types.d.ts",
    "util.ts",
    "native/**/*.ts",
    "tcp_client/*.ts"
  ],
  "scripts": {
    "prepare": "cp .hooks/* .git/hooks/ 2>/dev/null || true",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:native && npm run build:native:cjs && npm run build:full && npm run build:full:cjs && npm run build:lz4 && npm run build:lz4:cjs && npm run build:tcp && npm run build:tcp:cjs && npm run build:cli && npm run build:copy-wasm && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "build:cli": "esbuild tcp_client/cli.ts --bundle --format=esm --outfile=dist/cli.js --platform=node --target=es2022 --external:lz4-napi --external:zstd-napi",
    "build:copy-wasm": "cp node_modules/@bokuweb/zstd-wasm/dist/common/zstd.wasm dist/",
    "build:native": "esbuild native/index.ts --bundle --format=esm --outfile=dist/native.js --platform=neutral --target=es2022 --minify --external:lz4-napi --external:zstd-napi",
    "build:native:cjs": "esbuild native/index.ts --bundle --format=cjs --outfile=dist/native.cjs --platform=node --target=es2022 --minify --external:lz4-napi --external:zstd-napi",
    "build:full": "esbuild index.ts --bundle --format=esm --outfile=dist/chwire.js --platform=browser --target=es2022 --minify --define:BUILD_WITH_ZSTD=true --external:zstd-napi --external:lz4-napi --external:@maxjustus/chwire/native --alias:@maxjustus/chwire/native=@maxjustus/chwire/native",
    "build:full:cjs": "esbuild index.ts --bundle --format=cjs --outfile=dist/chwire.cjs --platform=node --target=es2022 --minify --define:BUILD_WITH_ZSTD=true --external:zstd-napi --external:lz4-napi --external:@maxjustus/chwire/native --alias:@maxjustus/chwire/native=@maxjustus/chwire/native",
    "build:lz4": "esbuild index.ts --bundle --format=esm --outfile=dist/chwire-lz4.js --platform=browser --target=es2022 --minify --define:BUILD_WITH_ZSTD=false --external:zstd-napi --external:lz4-napi --external:@maxjustus/chwire/native --alias:@maxjustus/chwire/native=@maxjustus/chwire/native",
    "build:lz4:cjs": "esbuild index.ts --bundle --format=cjs --outfile=dist/chwire-lz4.cjs --platform=node --target=es2022 --minify --define:BUILD_WITH_ZSTD=false --external:zstd-napi --external:lz4-napi --external:@maxjustus/chwire/native --alias:@maxjustus/chwire/native=@maxjustus/chwire/native",
    "build:tcp": "esbuild tcp_client/index.ts --bundle --format=esm --outfile=dist/tcp.js --platform=node --target=es2022 --minify --external:lz4-napi --external:zstd-napi --external:@maxjustus/chwire/native --alias:@maxjustus/chwire/native=@maxjustus/chwire/native",
    "build:tcp:cjs": "esbuild tcp_client/index.ts --bundle --format=cjs --outfile=dist/tcp.cjs --platform=node --target=es2022 --minify --external:lz4-napi --external:zstd-napi --external:@maxjustus/chwire/native --alias:@maxjustus/chwire/native=@maxjustus/chwire/native",
    "test": "tsc --noEmit && NODE_OPTIONS=--conditions=development tsx --test test/native/*.test.ts test/*.test.ts",
    "test:compression": "NODE_OPTIONS=--conditions=development tsx --test test/compression.test.ts",
    "test:integration": "NODE_OPTIONS=--conditions=development tsx --test test/http-integration.test.ts test/native/integration.test.ts test/native/integration_matrix.test.ts",
    "test:native": "NODE_OPTIONS=--conditions=development tsx --test test/native/*.test.ts",
    "test:dist": "npm run build && node test/test-dist.mjs",
    "test:fuzz": "tsx fuzz/parallel.ts --all",
    "test:fuzz:verbose": "tsx fuzz/parallel.ts --all --verbose",
    "test:tcp": "NODE_OPTIONS=--conditions=development tsx --test tcp_client/test/*.test.ts",
    "test:tcp:stress": "TCP_FUZZ_STRESS=1 QUERY_TIMEOUT=300000 NODE_OPTIONS=--conditions=development tsx --test tcp_client/test/fuzz.test.ts",
    "bench": "tsx bench/formats.ts",
    "bench:check": "tsc -p tsconfig.bench.json",
    "bench:compression": "tsx bench/compression.ts",
    "vendor:lz4": "npx jsr add @nick/lz4 && cp node_modules/@nick/lz4/lib/lz4.js node_modules/@nick/lz4/lib/lz4.internal.js vendor/lz4/ && rm -rf node_modules/@nick",
    "format": "biome format --write .",
    "format:check": "biome check ."
  },
  "author": "maxjustus",
  "license": "MIT",
  "dependencies": {
    "@bokuweb/zstd-wasm": "^0.0.27",
    "ch-city-wasm": "^0.1.1"
  },
  "optionalDependencies": {
    "lz4-napi": "^2.9.0",
    "zstd-napi": "^0.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@testcontainers/clickhouse": "^11.5.1",
    "esbuild": "^0.27.0",
    "testcontainers": "^11.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
